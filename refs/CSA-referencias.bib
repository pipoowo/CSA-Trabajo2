@article{alenda_mas_2024,
  title = {{M\'as All\'a del Fascismo: Una agenda de investigaci\'on sobre la nueva ultraderecha en Am\'erica Latina}},
  shorttitle = {{M\'as All\'a del Fascismo}},
  author = {Alenda, St{\'e}phanie and Escoffier, Sim{\'o}n},
  year = 2024,
  month = jul,
  journal = {Revista de Historia Social y de las Mentalidades},
  volume = {28},
  number = {1},
  pages = {255--290},
  issn = {0719-4749},
  doi = {10.35588/03e7wr10},
  urldate = {2026-06-30},
  abstract = {New particularities of the far-right in Latin America have allowed it to gain power over the last couple of decades. While the ideas of fascism and Nazism adequately reflected the development of authoritarian, xenophobic, and populist ideological forces during the first half of the 20th century, today, they are obsolete for referring to the tactics and impacts of this new far-right. Although conceptual frameworks on the issue invited to (re)classify the new ultra-right tendencies, the article proposes a relational perspective that identifies dynamics, evolutions, and positions of different expressions of the far right. After a conceptual and historical overview of the relationships between the new far right and fascism, we propose two avenues for future research. First, we explain that the growth of the new far-right depends mainly on the evolution of relationships and disputes between the institutional expressions of the right in their most radical and moderate versions. Second, we show that exploring the development of far-right civil society concerning institutional politics is essential for understanding its recent expansion.},
  copyright = {Derechos de autor 2024 Revista de Historia Social y de las Mentalidades},
  langid = {spanish},
  keywords = {America Latina,America Latina XX-XXI,Civil Society,Derecha,Direita,Extrema-direita,Far-right,Fascism,Fascismo,Latin America,Latin America XX-XXI,Right-wing,Sociedad Civil,Sociedade civil,Ultraderecha},
  file = {C:\Users\felip\Zotero\storage\973YVR2S\Alenda y Escoffier - 2024 - Más Allá del Fascismo Una agenda de investigación sobre la nueva ultraderecha en América Latina.pdf}
}

@article{atria_dilemas_2021,
  title = {Los Dilemas de La Meritocracia. {{Entrevista}} Con {{Fran\c cois Dubet}}},
  author = {Atria, Jorge},
  year = 2021,
  month = mar,
  journal = {Revista Mexicana de Sociolog\'ia},
  volume = {83},
  number = {2},
  issn = {2594-0651, 0188-2503},
  doi = {10.22201/iis.01882503p.2021.2.60092},
  urldate = {2026-06-30},
  abstract = {La idea de que el m\'erito puede prevalecer por sobre las ventajas adscritas ha adquirido creciente relevancia en las sociedades~actuales a trav\'es de un fuerte apoyo a la meritocracia. Aunque~este concepto fue concebido por Michael Young (1958), como una~descripci\'on dist\'opica de una sociedad en la que triunfaban los m\'as~talentosos, creando a su vez nuevas estratificaciones y ventajas~intergeneracionales, en las sociedades latinoamericanas su validez~ha sido discutida como forma de superar desigualdades arraigadas~que siguen exhibiendo el predominio de las condiciones sociales de~origen. En esta entrevista, el soci\'ologo Fran\c cois Dubet, conocido~experto en sociolog\'ia de educaci\'on, desigualdad e instituciones sociales,~conversa con el soci\'ologo Jorge Atria sobre los significados~del m\'erito y la meritocracia, los principios de justicia y las desigualdades~en Chile y las sociedades latinoamericanas, considerando tambi\'en el rol de las instituciones fiscales.}
}

